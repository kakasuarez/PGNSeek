# ── Elasticsearch ─────────────────────────────────────────────
ES_HOST=http://localhost:9200
ES_INDEX=chess_games
ES_INDEX_ALIAS=chess_games          # queries always hit the alias
ES_BULK_BATCH_SIZE=500              # docs per bulk request
ES_MAX_RESULT_WINDOW=10000          # default ES safety cap (use search_after beyond this)

# ── Ingestion pipeline ─────────────────────────────────────────
PGN_DATA_DIR=./data/pgn             # where your 7z-extracted PGN files live
INGESTION_STATE_FILE=./data/ingestion_state.json
MIN_YEAR=2010                       # skip games before this year

# ── Feature extraction thresholds ─────────────────────────────
AGGRESSION_THRESHOLD=3.0            # avg_material_swings above this = attacking game
SACRIFICE_DELTA=3                   # material swing >= this in one move = sacrifice
ENDGAME_MAX_PIECES=12               # total pieces on board to classify as endgame

# ── API ────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
RATE_LIMIT_PER_MINUTE=60

# ── Caching ────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300               # 5 min TTL on repeated identical queries
CACHE_MAX_SIZE=1000                 # max cached query results in memory

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                     # json (prod) | pretty (dev)
ENV=development                     # development | production
